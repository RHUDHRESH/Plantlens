{
  "version": "1.0.0",
  "scenarios": [
    {
      "id": "scn_motor_overload",
      "name": "Motor Mechanical Overload",
      "description": "Motor mechanical load rises first, then speed drops, then the DC bus sags, then inverter undervoltage appears downstream, then motor temperature rises. The hero scenario: 5 alarms must collapse into ONE situation rooted at the motor.",
      "duration_ms": 14000,
      "expected_situation": "MOTOR_MECHANICAL_OVERLOAD",
      "expected_root_cause": "MTR-301",
      "expected_alarms": ["MOTOR_CURRENT_HIGH", "MOTOR_SPEED_LOW", "DC_BUS_LOW", "INV_UNDERVOLTAGE", "MOTOR_TEMP_HIGH"],
      "events": [
        { "at_ms": 0, "action": "set", "tag": "MOTOR_301_CURRENT", "asset_id": "MTR-301", "value": 1.2, "unit": "A" },
        { "at_ms": 0, "action": "set", "tag": "MOTOR_301_RPM", "asset_id": "MTR-301", "value": 1450, "unit": "rpm" },
        { "at_ms": 0, "action": "set", "tag": "BUS_101_V", "asset_id": "BUS-101", "value": 48.0, "unit": "V" },
        { "at_ms": 0, "action": "set", "tag": "MOTOR_301_TEMP", "asset_id": "MTR-301", "value": 48.0, "unit": "C" },
        { "at_ms": 0, "action": "set", "tag": "INV_102_UNDERVOLTAGE", "asset_id": "INV-102", "value": false, "unit": "bool" },
        { "at_ms": 2000, "action": "set", "tag": "MOTOR_301_CURRENT", "asset_id": "MTR-301", "value": 3.4, "unit": "A" },
        { "at_ms": 4000, "action": "set", "tag": "MOTOR_301_RPM", "asset_id": "MTR-301", "value": 760, "unit": "rpm" },
        { "at_ms": 6000, "action": "set", "tag": "BUS_101_V", "asset_id": "BUS-101", "value": 40.5, "unit": "V" },
        { "at_ms": 7500, "action": "set", "tag": "INV_102_UNDERVOLTAGE", "asset_id": "INV-102", "value": true, "unit": "bool" },
        { "at_ms": 10000, "action": "ramp", "tag": "MOTOR_301_TEMP", "asset_id": "MTR-301", "from": 48.0, "to": 78.0, "over_ms": 3000, "unit": "C" }
      ]
    },
    {
      "id": "scn_pv_shade",
      "name": "PV Shade Event",
      "description": "PV current collapses (cloud/shade) so the bus sags from upstream. Root must be PV-101, NOT the bus. Tests upstream-vs-downstream discrimination.",
      "duration_ms": 12000,
      "expected_situation": "PV_GENERATION_LOSS",
      "expected_root_cause": "PV-101",
      "expected_alarms": ["DC_BUS_LOW"],
      "events": [
        { "at_ms": 0, "action": "set", "tag": "PV_101_I", "asset_id": "PV-101", "value": 9.8, "unit": "A" },
        { "at_ms": 0, "action": "set", "tag": "BUS_101_V", "asset_id": "BUS-101", "value": 48.0, "unit": "V" },
        { "at_ms": 5000, "action": "set", "tag": "PV_101_I", "asset_id": "PV-101", "value": 1.2, "unit": "A" },
        { "at_ms": 5200, "action": "set", "tag": "BUS_101_V", "asset_id": "BUS-101", "value": 40.0, "unit": "V" }
      ]
    },
    {
      "id": "scn_rs485_dropout",
      "name": "RS485 Dropout",
      "description": "Gateway stops responding; motor tags go STALE. Tests degraded mode: sensor_bad/offline status, 'data stale' badge, no confident root cause from stale data.",
      "duration_ms": 8000,
      "expected_situation": null,
      "expected_root_cause": null,
      "expected_alarms": [],
      "events": [
        { "at_ms": 0, "action": "set", "tag": "MOTOR_301_CURRENT", "asset_id": "MTR-301", "value": 1.2, "unit": "A" },
        { "at_ms": 3000, "action": "fault", "tag": "MOTOR_301_CURRENT", "asset_id": "MTR-301", "fault": { "type": "stale" }, "quality": "STALE" }
      ]
    }
  ]
}
