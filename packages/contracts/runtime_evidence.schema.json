{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plantlens.dev/contracts/runtime_evidence.schema.json",
  "title": "RuntimeEvidencePacket",
  "description": "Read-only deterministic evidence packet produced by the runtime cognition pipeline. Consumed by Calm Card, audit, incident room, and draft-only agents. Agents must not recompute root cause from this packet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "plant_id",
    "ts",
    "runtime_bundle_version",
    "source_frame_ids",
    "active_alarm_ids",
    "grouped_alarm_ids",
    "confidence",
    "confidence_reason",
    "evidence_chain",
    "causal_path",
    "rejected_candidates",
    "stale_or_bad_tags",
    "missing_tags",
    "blocked_actions",
    "recommended_checks",
    "deterministic_trace_id"
  ],
  "properties": {
    "evidence_id": { "type": "string" },
    "plant_id": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "runtime_bundle_version": { "type": "string" },
    "source_frame_ids": { "type": "array", "items": { "type": "string" } },
    "active_alarm_ids": { "type": "array", "items": { "type": "string" } },
    "grouped_alarm_ids": { "type": "array", "items": { "type": "string" } },
    "root_asset_id": { "type": ["string", "null"] },
    "root_cause_candidate_id": { "type": ["string", "null"] },
    "situation_id": { "type": ["string", "null"] },
    "situation_type": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_reason": { "type": "string" },
    "evidence_chain": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceChainItem" }
    },
    "causal_path": {
      "type": "array",
      "items": { "$ref": "#/$defs/CausalPathEdge" }
    },
    "rejected_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/RejectedCandidate" }
    },
    "stale_or_bad_tags": { "type": "array", "items": { "type": "string" } },
    "missing_tags": { "type": "array", "items": { "type": "string" } },
    "blocked_actions": { "type": "array", "items": { "type": "object" } },
    "recommended_checks": { "type": "array", "items": { "type": "object" } },
    "time_to_consequence": { "type": ["object", "null"] },
    "audit_receipt_id": { "type": ["string", "null"] },
    "deterministic_trace_id": { "type": "string" }
  },
  "$defs": {
    "EvidenceChainItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "asset_id", "alarm_id", "first_seen_ts", "quality", "role"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "tag_id": { "type": ["string", "null"] },
        "asset_id": { "type": "string" },
        "signal_name": { "type": ["string", "null"] },
        "observed_value": {},
        "unit": { "type": ["string", "null"] },
        "threshold": { "type": ["number", "null"] },
        "comparator": { "type": ["string", "null"] },
        "alarm_id": { "type": "string" },
        "first_seen_ts": { "type": "string", "format": "date-time" },
        "quality": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["first_signal", "supporting_signal", "downstream_effect", "rejected", "sensor_fault"]
        },
        "explanation": { "type": "string" }
      }
    },
    "CausalPathEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_asset_id", "to_asset_id", "edge_id", "approved", "relation_type"],
      "properties": {
        "from_asset_id": { "type": "string" },
        "to_asset_id": { "type": "string" },
        "edge_id": { "type": "string" },
        "approved": { "type": "boolean" },
        "lag_ms": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
        "observed_lag_ms": { "type": ["number", "null"] },
        "relation_type": { "type": "string" },
        "explanation": { "type": "string" }
      }
    },
    "RejectedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "reason", "score"],
      "properties": {
        "asset_id": { "type": "string" },
        "reason": { "type": "string" },
        "score": { "type": "number" },
        "missing_evidence": { "type": "array", "items": { "type": "string" } },
        "contradicted_by": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}