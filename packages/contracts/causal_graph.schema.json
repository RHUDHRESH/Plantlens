{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plantlens.dev/contracts/causal_graph.schema.json",
  "title": "CausalGraph",
  "description": "The runtime truth (rule R2). The DAG runtime ONLY traverses edges with approved=true, within each edge's lag window. Must be acyclic (validated at compile via topological sort). No AI bypasses this; AI may only PROPOSE edges that a human approves offline.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "graph_id", "nodes", "edges"],
  "properties": {
    "version": { "type": "string" },
    "graph_id": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["asset", "alarm", "situation", "condition", "consequence"] },
          "evidence_tags": { "type": "array", "items": { "type": "string" } },
          "label": { "type": "string" },
          "fingerprint_rules": {
            "type": "array",
            "items": { "$ref": "#/$defs/fingerprint_rule" }
          },
          "score_adjustments": {
            "type": "array",
            "items": { "$ref": "#/$defs/score_adjustment" }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "edge_type", "approved", "provenance"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "edge_type": {
            "type": "string",
            "enum": ["structural_power", "structural_load_effect", "signal", "thermal", "mechanical", "control", "cause_to_effect"]
          },
          "approved": { "type": "boolean" },
          "lag_ms": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2
          },
          "weight": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
          "provenance": {
            "type": "string",
            "enum": ["cause_effect_matrix", "hazop", "pid", "historian", "operator_note", "manual", "engineer_entered", "agent_proposed"]
          }
        }
      }
    },
    "root_cause_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_node", "conditions"],
        "properties": {
          "target_node": { "type": "string" },
          "logic": { "type": "string", "description": "Human-readable summary for Studio display." },
          "conditions": {
            "type": "array",
            "items": { "$ref": "#/$defs/condition" },
            "minItems": 1
          },
          "score_bonus": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 }
        }
      }
    },
    "situation_types": {
      "type": "array",
      "description": "Config-driven situation fingerprints. Runtime infers situation_type from these, never hardcoded dicts.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "root_asset_id", "required_alarms"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "root_asset_id": { "type": "string" },
          "required_alarms": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "require_all_alarms": { "type": "boolean", "default": true },
          "evidence_order": { "type": "array", "items": { "type": "string" } },
          "extra_conditions": {
            "type": "array",
            "items": { "$ref": "#/$defs/condition" }
          },
          "min_root_score": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.1 }
        }
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["alarms_all", "alarms_any", "alarms_absent", "alarm_before", "tag_threshold", "tag_quality_good"]
        },
        "alarm_ids": { "type": "array", "items": { "type": "string" } },
        "first": { "type": "string" },
        "second": { "type": "string" },
        "tag_id": { "type": "string" },
        "op": { "type": "string", "enum": ["lt", "lte", "gt", "gte", "eq"] },
        "value": { "type": "number" }
      }
    },
    "fingerprint_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conditions", "score_bonus"],
      "properties": {
        "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" }, "minItems": 1 },
        "score_bonus": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason": { "type": "string" }
      }
    },
    "score_adjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "multiply"],
      "properties": {
        "when": { "type": "array", "items": { "$ref": "#/$defs/condition" }, "minItems": 1 },
        "multiply": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason": { "type": "string" }
      }
    }
  }
}