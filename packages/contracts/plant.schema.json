{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plantlens.dev/contracts/plant.schema.json",
  "title": "Plant",
  "description": "Canonical static plant model. The single 'what exists and where it sits' truth that 2D map, 3D map, React Flow, and the compiler all read. Authored in Studio forms; never hand-edited in the DB.",
  "type": "object",
  "additionalProperties": false,
  "required": ["plant_id", "name", "version", "assets", "connections"],
  "properties": {
    "plant_id": { "type": "string", "description": "Stable id, e.g. demo_microgrid_001." },
    "name": { "type": "string" },
    "version": { "type": "string", "description": "Semver of this authored model. Bumped on every save; the compiler hashes the full bundle." },
    "timezone": { "type": "string", "description": "IANA tz, e.g. Asia/Kolkata. Used only for display; storage is UTC." },
    "topology": { "type": "string", "description": "Free-form classifier, e.g. electrical_dc_microgrid." },
    "areas": {
      "type": "array",
      "description": "Logical zones/areas. Optional grouping for navigation and role filtering.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string", "description": "e.g. generation | distribution | consumption." }
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "display_name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9-]+$", "description": "Unique asset id, e.g. MTR-301." },
          "type": {
            "type": "string",
            "description": "Asset archetype. Drives the symbol, default Calm Card, and validation rules.",
            "enum": [
              "source.solar", "source.mains", "storage.battery", "distribution.dc_bus",
              "distribution.breaker", "drive.inverter", "control.charge_controller",
              "load.motor_3phase", "load.lamp", "sensor.voltage", "sensor.current",
              "sensor.rpm", "sensor.temperature", "sensor.vibration", "control.plc", "control.hmi"
            ]
          },
          "display_name": { "type": "string" },
          "area_id": { "type": "string", "description": "Must match an areas[].id if areas are used." },
          "parent_asset_id": { "type": ["string", "null"], "description": "Structural parent (e.g. a motor's parent is its inverter). Must resolve." },
          "criticality": { "type": "string", "enum": ["low", "medium", "high"], "default": "medium" },
          "coords_2d": {
            "type": "object", "additionalProperties": false, "required": ["x", "y"],
            "description": "SVG canvas coordinates for the 2D map. The compiler warns if missing.",
            "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
          },
          "coords_3d": {
            "type": "object", "additionalProperties": false, "required": ["x", "y", "z"],
            "description": "Scene coordinates for the 3D map (+ optional model name).",
            "properties": {
              "x": { "type": "number" }, "y": { "type": "number" }, "z": { "type": "number" },
              "model": { "type": "string", "description": "GLTF/primitive name, e.g. inverter_box. Compiler warns if missing (defaults to a box)." }
            }
          },
          "meta": { "type": "object", "description": "Free-form per-asset metadata (ratings, chemistry, etc.).", "additionalProperties": true }
        }
      }
    },
    "connections": {
      "type": "array",
      "description": "Directed links between assets. Power flows downstream; this seeds the structural edges of the causal graph.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "description": "Source asset id; must exist." },
          "to": { "type": "string", "description": "Target asset id; must exist." },
          "kind": { "type": "string", "enum": ["power", "signal", "cooling", "process"], "default": "power" },
          "from_port": { "type": "string" },
          "to_port": { "type": "string" }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": { "type": "string", "enum": ["operator", "engineer", "maintenance", "supervisor", "admin"] },
      "description": "Roles this plant supports; drives role_views in the compiled HMI."
    }
  }
}
