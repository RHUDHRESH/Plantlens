# Copy to .env. apps/api/app/settings.py reads these via pydantic-settings BaseSettings.

# --- Core ---
PLANTLENS_ENV=dev                       # dev | staging | prod
PLANTLENS_LOG_LEVEL=info

# --- Database ---
# MVP (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./plantlens.db
# Production (Postgres): DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/plantlens

# --- Plant / compiler ---
ACTIVE_PLANT_ID=demo_microgrid_001
SAMPLE_DATA_DIR=../../packages/sample-data/demo-microgrid
COMPILED_DIR=./compiled

# --- Auth (OIDC) — leave blank to use the local-dev bootstrap in auth/ ---
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
# Dev/test only — signed HS256 tokens when OIDC is unset (never set in prod):
PLANTLENS_DEV_JWT_SECRET=

# --- Gateway / agents (the API publishes to / receives from these) ---
GATEWAY_INGEST_TOKEN=change-me          # shared secret the gateway uses to POST frames
AGENTS_BASE_URL=http://localhost:8100   # optional; agents service

# --- Observability (optional, Chunk 13) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
