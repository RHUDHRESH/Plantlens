{
  "name": "plantlens",
  "version": "0.1.0",
  "private": true,
  "description": "PlantLens monorepo root. Orchestrates the web app + shared JS packages. Python apps are managed separately by uv.",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter @plantlens/web dev",
    "build:web": "pnpm --filter @plantlens/web build",
    "test:web": "pnpm --filter @plantlens/web test",
    "oracle": "pnpm --filter @plantlens/cliffords test",
    "contracts:validate": "node scripts/validate-contracts.mjs",
    "compose:config": "docker compose -f deploy/docker/compose.full.yml config",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
